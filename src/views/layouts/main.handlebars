<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        h1 {
            color: white;
            text-align: center;
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 30px;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
        }

        /* NAV */
        nav {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }

        nav a {
            padding: 14px 32px;
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(10px);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 500;
            font-size: 1rem;
            transition: all 0.3s ease;
            border: 2px solid rgba(255, 255, 255, 0.3);
        }

        nav a:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        /* PRODUCT GRID */
        .product-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 20px;
        }

        .product-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            position: relative;
            overflow: hidden;
            animation: fadeIn 0.5s ease forwards;
        }

        .product-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #667eea, #764ba2);
        }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.2);
        }

        .product-card h3 {
            margin: 0 0 12px 0;
            color: #1a1a2e;
            font-size: 1.3rem;
            font-weight: 600;
        }

        .product-card p {
            color: #666;
            margin: 8px 0;
            line-height: 1.5;
        }

        .product-card .price {
            font-size: 1.6rem;
            color: #667eea;
            font-weight: 700;
            margin: 15px 0;
        }

        .product-card .stock {
            color: #27ae60;
            font-weight: 600;
        }

        .category {
            display: inline-block;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .card-actions {
            margin-top: 16px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-detail {
            flex: 1;
            text-align: center;
            padding: 10px 16px;
            background: #f0f0f0;
            color: #333;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-detail:hover {
            background: #e0e0e0;
        }

        .btn-cart,
        .btn-cart-big {
            flex: 1;
            padding: 10px 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

        .btn-cart:hover,
        .btn-cart-big:hover {
            transform: scale(1.02);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }

        .btn-cart-big {
            flex: none;
            width: 100%;
            padding: 16px;
            font-size: 1.1rem;
            margin-top: 20px;
        }

        /* FILTERS */
        .filters {
            background: white;
            border-radius: 16px;
            padding: 20px 24px;
            margin-bottom: 30px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
        }

        .filter-form {
            display: flex;
            gap: 16px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .filter-group label {
            font-weight: 500;
            color: #1a1a2e;
            font-size: 0.9rem;
        }

        .filter-group input,
        .filter-group select {
            padding: 10px 14px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 1rem;
            font-family: inherit;
            transition: border-color 0.2s;
        }

        .filter-group input:focus,
        .filter-group select:focus {
            outline: none;
            border-color: #667eea;
        }

        .btn-filter {
            padding: 10px 24px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
        }

        .btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }

        /* PAGINATION */
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            margin-top: 40px;
        }

        .btn-page {
            padding: 12px 24px;
            background: rgba(255, 255, 255, 0.9);
            color: #667eea;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.2s;
        }

        .btn-page:hover {
            background: white;
            transform: translateY(-2px);
        }

        .btn-page.disabled {
            opacity: 0.4;
            pointer-events: none;
        }

        .page-info {
            color: white;
            font-weight: 600;
            font-size: 1.1rem;
        }

        /* PRODUCT DETAIL */
        .product-detail {
            max-width: 700px;
            margin: 0 auto;
        }

        .detail-card {
            background: white;
            border-radius: 20px;
            padding: 36px;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15);
            margin-top: 20px;
        }

        .detail-card h1 {
            color: #1a1a2e;
            font-size: 2rem;
            margin-bottom: 16px;
            text-align: left;
            text-shadow: none;
        }

        .detail-description {
            color: #555;
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 24px;
        }

        .detail-info {
            border-top: 1px solid #eee;
            padding-top: 20px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f5f5f5;
        }

        .info-row .label {
            font-weight: 600;
            color: #1a1a2e;
        }

        .info-row .price {
            font-size: 1.5rem;
            color: #667eea;
            font-weight: 700;
        }

        .product-images {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .product-images img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 10px;
        }

        /* CART */
        .cart-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .cart-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-top: 20px;
        }

        .cart-item {
            background: white;
            border-radius: 16px;
            padding: 20px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
            flex-wrap: wrap;
            gap: 16px;
        }

        .cart-item-info h3 {
            color: #1a1a2e;
            font-size: 1.2rem;
            margin-bottom: 6px;
        }

        .cart-item-info .price {
            font-size: 1.3rem;
            color: #667eea;
            font-weight: 700;
        }

        .cart-item-info .category {
            font-size: 0.85rem;
        }

        .cart-item-actions {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .cart-item-actions label {
            font-weight: 500;
            color: #555;
        }

        .qty-input {
            width: 70px;
            padding: 8px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 1rem;
            text-align: center;
        }

        .btn-remove {
            padding: 8px 16px;
            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-remove:hover {
            transform: scale(1.03);
        }

        .cart-footer {
            margin-top: 24px;
            text-align: right;
        }

        .btn-clear {
            padding: 12px 28px;
            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .btn-clear:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(238, 90, 90, 0.4);
        }

        /* BACK BUTTON */
        .btn-back {
            display: inline-block;
            color: white;
            text-decoration: none;
            font-weight: 500;
            margin-bottom: 20px;
            opacity: 0.85;
            transition: opacity 0.2s;
        }

        .btn-back:hover {
            opacity: 1;
        }

        /* MISC */
        .empty-message {
            text-align: center;
            color: white;
            font-size: 1.2rem;
            padding: 60px 20px;
        }

        .empty-message h2 {
            font-size: 2rem;
            margin-bottom: 16px;
        }

        .empty-message p {
            margin-bottom: 24px;
        }

        .delete-btn {
            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            margin-top: 15px;
            font-weight: 500;
            transition: all 0.3s ease;
            width: 100%;
        }

        .delete-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 5px 15px rgba(238, 90, 90, 0.4);
        }

        /* FORMS */
        .form-container {
            background: white;
            padding: 35px;
            border-radius: 20px;
            margin-bottom: 40px;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15);
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        .form-container h2 {
            color: #1a1a2e;
            margin-bottom: 25px;
            font-size: 1.5rem;
            text-align: center;
        }

        .form-container form {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .form-container label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #1a1a2e;
        }

        .form-container input,
        .form-container select {
            width: 100%;
            padding: 14px;
            border: 2px solid #e0e0e0;
            border-radius: 10px;
            font-size: 1rem;
            transition: border-color 0.3s ease;
            font-family: inherit;
        }

        .form-container input:focus,
        .form-container select:focus {
            outline: none;
            border-color: #667eea;
        }

        .form-container button {
            grid-column: span 2;
            padding: 16px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            font-size: 1.1rem;
            font-weight: 600;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .form-container button:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <nav>
            <a href="/home">🏠 Home</a>
            <a href="/products">🛍️ Productos</a>
            <a href="/realtimeproducts">⚡ Tiempo Real</a>
            <a href="#" onclick="goToCart()">🛒 Mi Carrito</a>
        </nav>

        {{{body}}}
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        function goToCart() {
            const cartId = localStorage.getItem('cartId');
            if (cartId) {
                window.location.href = `/carts/${cartId}`;
            } else {
                Swal.fire({
                    icon: 'info',
                    title: 'Carrito vacío',
                    text: 'Agregá productos primero'
                });
            }
        }
    </script>
</body>

</html>